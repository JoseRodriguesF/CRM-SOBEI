generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  PAGA
  PENDENTE
  ATRASADA
}

model Company {
  id        Int       @id @default(autoincrement())
  name      String
  cnpj      String    @unique
  units     Unit[]
  invoices  Invoice[]
  createdAt DateTime  @default(now())
}

model Unit {
  id         Int       @id @default(autoincrement())
  name       String
  code       String
  company    Company   @relation(fields: [companyId], references: [id])
  companyId  Int
  invoices   Invoice[]
}

model Invoice {
  id           Int           @id @default(autoincrement())
  company      Company       @relation(fields: [companyId], references: [id])
  companyId    Int
  unit         Unit?         @relation(fields: [unitId], references: [id])
  unitId       Int?
  cnpj         String
  referenceMonth String
  totalAmount  Decimal       @db.Numeric(12, 2)
  dueDate      DateTime
  status       InvoiceStatus
  pdfPath      String
  createdAt    DateTime      @default(now())
}
