// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  PAGA
  ABERTA
}

model Company {
  id        Int       @id @default(autoincrement())
  name      String
  cnpj      String    @unique
  units     Unit[]
  invoices  Invoice[]
  createdAt DateTime  @default(now())
}

model Unit {
  id         Int       @id @default(autoincrement())
  name       String
  code       String
  cnpjs      String?   // JSON array de CNPJs, ex: ["12.345.678/0001-00", "98.765.432/0001-00"]
  address    String?
  company    Company   @relation(fields: [companyId], references: [id])
  companyId  Int
  invoices   Invoice[]
  services   Service[]
}

model Service {
  id           Int       @id @default(autoincrement())
  name         String    // Ex: "Móvel", "Internet", "Fixo"
  contractNumber String  // Número do contrato
  unit         Unit      @relation(fields: [unitId], references: [id])
  unitId       Int
  invoices     Invoice[]
  createdAt    DateTime  @default(now())
}

model Invoice {
  id             Int           @id @default(autoincrement())
  company        Company       @relation(fields: [companyId], references: [id])
  companyId      Int
  unit           Unit?         @relation(fields: [unitId], references: [id])
  unitId         Int?
  service        Service?      @relation(fields: [serviceId], references: [id])
  serviceId      Int?
  cnpj           String
  referenceMonth String
  totalAmount    Decimal
  dueDate        DateTime
  status         InvoiceStatus
  paidDate       DateTime?     // Data em que a fatura foi paga
  serviceName    String?       // Nome do serviço extraído da fatura (cache/referência)
  pdfPath        String
  createdAt      DateTime      @default(now())
}
